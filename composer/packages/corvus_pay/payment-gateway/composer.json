  "require": {
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-simplexml": "*",
    "corvuspay/corvuspay_wallet_php_sdk": "^1.0.0"
  },
  "type": "magento2-module",
